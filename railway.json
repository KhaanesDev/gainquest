{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install && npm run build",
    "watchPatterns": [
      "backend/**",
      "package.json",
      "package-lock.json",
      ".node-version",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "cd backend && npm start",
    "healthcheckPath": "/health"
  }
}
